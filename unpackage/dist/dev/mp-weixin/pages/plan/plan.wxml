Start||'请选择'}}</text><text class="picker-arrow data-v-3bdd76a6">📅</text></view></picker></view><view class="form-group half data-v-3bdd76a6"><text class="form-label data-v-3bdd76a6">返回日期</text><picker mode="date" value="{{newEnd}}" data-event-opts="{{[['change',[['onEndChange',['$event']]]]]}}" bindchange="__e" class="data-v-3bdd76a6"><view class="form-picker data-v-3bdd76a6"><text class="data-v-3bdd76a6">{{newEnd||'请选择'}}</text><text class="picker-arrow data-v-3bdd76a6">📅</text></view></picker></view></view><view class="form-group data-v-3bdd76a6"><text class="form-label data-v-3bdd76a6">预算（元）</text><input class="form-input data-v-3bdd76a6" type="number" placeholder="例如：8000" placeholder-style="color:#B89AAA" data-event-opts="{{[['input',[['__set_model',['','newBudget','$event',[]]]]]]}}" value="{{newBudget}}" bindinput="__e"/></view><view class="form-group data-v-3bdd76a6"><text class="form-label data-v-3bdd76a6">行程亮点（逗号分隔）</text><input class="form-input data-v-3bdd76a6" placeholder="例如：岚山,清水寺,祇园" placeholder-style="color:#B89AAA" data-event-opts="{{[['input',[['__set_model',['','newHighlights','$event',[]]]]]]}}" value="{{newHighlights}}" bindinput="__e"/></view><view class="form-group data-v-3bdd76a6"><text class="form-label data-v-3bdd76a6">状态</text><picker value="{{newStatusIndex}}" range="{{statusOptions}}" data-event-opts="{{[['change',[['onNewStatusChange',['$event']]]]]}}" bindchange="__e" class="data-v-3bdd76a6"><view class="form-picker data-v-3bdd76a6"><text class="data-v-3bdd76a6">{{statusOptions[newStatusIndex]}}</text><text class="picker-arrow data-v-3bdd76a6">▾</text></view></picker></view><view data-event-opts="{{[['tap',[['submitPlan',['$event']]]]]}}" class="modal-btn data-v-3bdd76a6" bindtap="__e">🚀 创建计划</view></view></view></block></view>